/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://freeipapi.com; base-uri 'self'; frame-ancestors 'none'; form-action 'self'

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/*.css
  Cache-Control: public, max-age=0, must-revalidate

/*.js
  Cache-Control: public, max-age=0, must-revalidate

/*.mjs
  Cache-Control: public, max-age=0, must-revalidate

# Findings pages are static and purged on every deploy — edge-cache them so
# visitors and crawlers get instant responses (prevents cold-fetch timeouts
# that can fail Google indexing requests).
/findings/*
  Cache-Control: public, max-age=600, s-maxage=86400

/favicon.*
  Cache-Control: public, max-age=31536000, immutable

/api/*
  Cache-Control: no-store

# OpenAPI spec — explicit YAML content-type for tools that sniff it.
/api/openapi.yaml
  Content-Type: application/yaml; charset=utf-8
  Cache-Control: public, max-age=300
  Access-Control-Allow-Origin: *

# Postman collection — explicit JSON content-type and short edge cache.
/api/postman.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=300
  Access-Control-Allow-Origin: *

# RapiDoc is self-hosted at /api/docs/rapidoc-min.js (same-origin) so the
# global CSP allows it; no per-route CSP override needed.
