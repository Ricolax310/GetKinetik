/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/*.css
  Cache-Control: public, max-age=0, must-revalidate

/*.js
  Cache-Control: public, max-age=0, must-revalidate

/*.mjs
  Cache-Control: public, max-age=0, must-revalidate

/favicon.*
  Cache-Control: public, max-age=31536000, immutable

/api/*
  Cache-Control: no-store

# OpenAPI spec — explicit YAML content-type for tools that sniff it.
/api/openapi.yaml
  Content-Type: application/yaml; charset=utf-8
  Cache-Control: public, max-age=300
  Access-Control-Allow-Origin: *

# Postman collection — explicit JSON content-type and short edge cache.
/api/postman.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=300
  Access-Control-Allow-Origin: *

# Interactive docs viewer — RapiDoc loads from unpkg.com, so the strict
# global CSP would block it. This route gets a scoped CSP override:
# allow scripts/styles from unpkg + self only. No data leaves the page.
/api/docs/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https://unpkg.com; img-src 'self' data:; font-src 'self' data: https://unpkg.com; connect-src 'self'; base-uri 'self'; frame-ancestors 'none'
