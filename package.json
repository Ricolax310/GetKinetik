{
  "name": "getkinetik",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start --go",
    "android": "expo start --android --dev-client",
    "ios": "expo start --ios --dev-client",
    "web": "expo start --web",
    "eas:login": "npx eas-cli@latest login",
    "eas:init": "npx eas-cli@latest init",
    "eas:build:dev": "npx eas-cli@latest build --profile development --platform android",
    "eas:build:preview": "npx eas-cli@latest build --profile preview --platform android",
    "eas:build:apk": "npx eas-cli@latest build --profile preview --platform android",
    "eas:build:aab": "npx eas-cli@latest build --profile production --platform android",
    "bureau:status": "node scripts/bureau-run.mjs status",
    "bureau:scan": "node scripts/bureau-run.mjs scan all",
    "bureau:outreach": "node scripts/bureau-run.mjs outreach all",
    "bureau:pipeline": "node scripts/bureau-run.mjs pipeline",
    "bureau:brief": "node scripts/bureau-run.mjs brief",
    "bureau:publish": "node scripts/bureau-run.mjs publish",
    "bureau:weekly": "node scripts/bureau-run.mjs pipeline --force",
    "bureau:news": "node scripts/bureau-run.mjs news",
    "bureau:news:post": "node scripts/bureau-run.mjs news --post",
    "git:hooks-install": "node scripts/install-git-hooks.mjs",
    "git:sync": "node scripts/git-sync.mjs",
    "git:push": "node scripts/git-push.mjs",
    "bureau:depin-context": "node scripts/bureau/build-depin-chat-context.mjs",
    "bureau:ops": "node scripts/serve-bureau-ops.mjs",
    "signal:daily": "node scripts/signal-pipeline/pipeline.mjs daily",
    "signal:weekly": "node scripts/signal-pipeline/pipeline.mjs weekly",
    "signal:monthly": "node scripts/signal-pipeline/pipeline.mjs monthly",
    "signal:all": "node scripts/signal-pipeline/pipeline.mjs all",
    "signal:daily:live": "node scripts/signal-pipeline/pipeline.mjs daily --live",
    "signal:schedule": "node scripts/signal-pipeline/scheduler.mjs",
    "signal:run": "node scripts/signal-pipeline/run.mjs",
    "signal:replay": "node -e \"import('./scripts/signal-pipeline/tracer.mjs').then(async ({replayTrace,listTraces})=>{ const id=process.argv[2]; if(!id){console.log(JSON.stringify(listTraces(),null,2));process.exit(0);} const {runCompiler}=await import('./scripts/signal-pipeline/engine.mjs'); const r=await replayTrace(id,runCompiler); console.log(JSON.stringify(r,null,2)); }).catch(e=>{console.error(e.message);process.exit(1);})\" --",
    "drip:daily": "node drip-engine/run.ts daily",
    "drip:weekly": "node drip-engine/run.ts weekly",
    "drip:monthly": "node drip-engine/run.ts monthly",
    "drip:intro": "node scripts/drip/post-intro.mjs",
    "drip:all": "node drip-engine/run.ts all",
    "command-center:morning": "node scripts/command-center/build.mjs --fetch-rss",
    "command-center:daily": "node scripts/command-center/build.mjs --fetch-rss",
    "command-center": "node scripts/serve-command-center.mjs",
    "command-center:build": "node scripts/command-center/build.mjs",
    "command-center:open": "powershell -NoProfile -ExecutionPolicy Bypass -File \"scripts/command-center/open-command-center.ps1\"",
    "command-center:install-shortcut": "powershell -NoProfile -ExecutionPolicy Bypass -File \"scripts/command-center/install-shortcut.ps1\"",
    "anchor:daily": "node scripts/anchor-daily-cids.mjs",
    "fuzz:verify-device": "node scripts/fuzz/fuzz-verify-device.mjs",
    "smoke:depin-chat": "node scripts/smoke/depin-chat-smoke.mjs",
    "smoke:depin-chat:live": "node scripts/smoke/depin-chat-smoke.mjs --live",
    "fuzz:smoke": "node scripts/fuzz/fuzz-verify-device.mjs --count 250",
    "verify:smoke": "npm --prefix packages/verify run build && node packages/verify/smoketest.mjs",
    "verifier:sync": "npm --prefix packages/verify run build && node scripts/sync-verifier.mjs",
    "verifier:parity": "npm run verifier:sync && node scripts/test-verifier-parity.mjs",
    "verify:integrity": "npm run verify:smoke && npm run fuzz:smoke && node scripts/fuzz/regression-score-bounds.mjs",
    "esm:check:expo-config": "npx expo config --json",
    "esm:check:babel-config": "node -e \"const cfg=require('./babel.config.cjs'); const out=typeof cfg==='function'?cfg({cache:()=>{}}):cfg; if(!out||!Array.isArray(out.presets)) throw new Error('Invalid Babel config'); console.log('babel-config-ok');\"",
    "esm:check:nodle-plugin": "node -e \"const plugin=require('./modules/nodle-sdk/app.plugin.js'); if(typeof plugin!=='function') throw new Error('Nodle plugin must export a function'); console.log('nodle-plugin-ok');\"",
    "esm:preflight": "npm run esm:check:expo-config && npm run esm:check:babel-config && npm run esm:check:nodle-plugin && npm run verify:integrity",
    "policy:build": "tsc -p packages/evidence-mapping/tsconfig.json",
    "policy:sync": "npm run policy:build && node scripts/sync-worker-policy.mjs",
    "policy:parity": "npm run policy:build && node scripts/test-policy-parity.mjs",
    "policy:smoke": "npm run policy:build && node packages/evidence-mapping/smoketest.mjs",
    "canonical:sync": "node scripts/sync-canonicalizer.mjs",
    "canonical:parity": "npm --prefix packages/verify run build && node scripts/test-canonicalizer-parity.mjs"
  },
  "dependencies": {
    "@getkinetik/react-native-sdk": "file:./modules/kinetik-sdk",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "@shopify/react-native-skia": "2.2.12",
    "dotenv": "^17.4.2",
    "expo": "~54.0.34",
    "expo-application": "~7.0.8",
    "expo-battery": "~10.0.7",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-dev-client": "~6.0.21",
    "expo-haptics": "~15.0.7",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "^56.0.12",
    "expo-secure-store": "~15.0.8",
    "expo-sensors": "~15.0.7",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.11",
    "nodle-sdk": "file:./modules/nodle-sdk",
    "qrcode-generator": "2.0.4",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "~4.1.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-worklets": "^0.5.1"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.98.4",
    "@types/qrcode-generator": "^0.0.16",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.5",
    "bs58": "^6.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
