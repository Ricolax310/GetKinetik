# GETKINETIK — copy to .env and fill in values (never commit .env)

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
BUREAU_NEWS_MODEL=gpt-5
BUREAU_DEPIN_CHAT_MODEL=gpt-4o-mini
BUREAU_OPS_CHAT_MODEL=gpt-4o-mini
# BUREAU_NEWS_MIN_CONFIDENCE=0.85
# BUREAU_NEWS_MAX_LLM=3

# ── Hugging Face ─────────────────────────────────────────────────────────────
# Token needs WRITE (to publish the dataset) + Inference (for embeddings).
# Create at https://huggingface.co/settings/tokens
HF_TOKEN=
# Optional overrides:
# HF_DATASET_ID=ericmg310/getkinetik-signal-reports
# BUREAU_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# BUREAU_RERANK_MODEL=          # leave empty to disable the rerank stage

# ── X / Twitter (optional) ──────────────────────────────────────────────────
# Bureau / @kinetiksignal account — the drip-engine posts the daily signal card.
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=
# @Kinetik_Rick personal account — quote-tweets the signal post to drive traffic.
# Access tokens MUST be Rick's own (the app keys can be shared via X_API_KEY/SECRET).
# RICK_X_API_KEY=
# RICK_X_API_SECRET=
# RICK_X_ACCESS_TOKEN=
# RICK_X_ACCESS_SECRET=
BUREAU_AUTO_POST=false

# ── Solana ──────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# JSON array from: node -e "const k=require('@solana/web3.js').Keypair.generate(); console.log(JSON.stringify(Array.from(k.secretKey)))"
BUREAU_WALLET_KEY=

# ── IPFS (Pinata) ───────────────────────────────────────────────────────────
PINATA_JWT=

# ── Cloudflare D1 ───────────────────────────────────────────────────────────
CF_ACCOUNT_ID=
D1_DATABASE_ID=
D1_API_TOKEN=

# ── DIMO (optional) ─────────────────────────────────────────────────────────
# DIMO_API_KEY=
# DIMO_CLIENT_ID=
# DIMO_REDIRECT_URI=https://getkinetik.app/dimo-callback

# ── Local bureau ops (npm run bureau:ops — localhost only) ───────────────────
# BUREAU_OPS_CHAT_MODEL=gpt-4o-mini
# BUREAU_OPS_PORT=5199

METHODOLOGY_VERSION=v1.1

# ── Cloudflare Pages (public /bureau/ask only) ───────────────────────────────
# OPENAI_API_KEY              — same key as above
# BUREAU_DEPIN_CHAT_MODEL     — optional
# BUREAU_SIGNING_KEY_HEX
# BUREAU_PUBKEY_HEX
# ATTEST_API_KEY
