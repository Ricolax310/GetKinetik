#!/bin/sh
# Auto-installed by: npm run git:hooks-install
# Rebases onto origin/main before push so bureau GitHub Action commits don't block you.

set -e

branch=$(git symbolic-ref --short HEAD 2>/dev/null) || exit 0

case "$branch" in
  main|master) ;;
  *) exit 0 ;;
esac

remote="${1:-origin}"
upstream="${remote}/${branch}"

if ! git diff-index --quiet HEAD -- 2>/dev/null; then
  echo ""
  echo "pre-push: You have uncommitted changes."
  echo "  Commit or stash first, then push again."
  echo "  Or run: npm run git:sync   (pull only)"
  echo ""
  exit 1
fi

echo "pre-push: fetching ${upstream}..."
git fetch "$remote" "$branch" 2>/dev/null || git fetch "$remote"

behind=$(git rev-list --count "HEAD..${upstream}" 2>/dev/null || echo 0)
if [ "$behind" -eq 0 ]; then
  exit 0
fi

echo ""
echo "pre-push: ${upstream} is ${behind} commit(s) ahead (often daily bureau automation)."
echo "pre-push: rebasing your commits on top..."
echo ""

if ! git pull --rebase "$remote" "$branch"; then
  echo ""
  echo "pre-push: rebase failed."
  echo "  1. Fix conflicts in the files listed above"
  echo "  2. git add <fixed files>"
  echo "  3. git rebase --continue"
  echo "  4. git push origin ${branch}"
  echo "  Or abort: git rebase --abort"
  echo ""
  exit 1
fi

echo "pre-push: rebase done — continuing push."
exit 0
