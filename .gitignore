# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env.local
.env*.local
secrets.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Local APK builds (downloaded from EAS, not tracked)
*.apk

# Scratch commit-message tempfiles (used to side-step PowerShell heredoc limits)
.git-commit-msg.tmp

# Bureau automation (local runs — review before commit)
docs/outreach/generated/*
!docs/outreach/generated/.gitkeep
scripts/data/bureau-run-log.json

# Private ops — lives in the private getkinetik-ops repo, never committed here.
# Local tooling still reads/writes these paths; they just stay out of git.
docs/bureau/private/
docs/bureau/daily/
docs/bureau/operator-tasks.md
docs/bureau/OPS_CALENDAR.md
docs/outreach/
docs/funding/
docs/command-center/
scripts/bureau/gtm-context.md
INVESTOR_PITCH.md
PITCH_DECK.md
OUTREACH_MESSAGES.md
OUTREACH_SENDLIST.md
PARTNER_EMAILS.md
FUNDING_TEMPLATES.md
FUNDING.json
GRANT_APPLICATIONS_READY.md
NETWORK_READS_TRACK.md
